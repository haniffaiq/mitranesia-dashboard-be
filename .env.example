APP_NAME="Mitra Revamp Dashboard API"
APP_ENV=development
POSTGRES_DB=mitranesia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:your-password@your-host:5432/mitranesia
PSQL_DATABASE_URL=postgresql://postgres:your-password@your-host:5432/mitranesia
JWT_SECRET_KEY=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:3000,http://localhost:5001,http://localhost:5002,http://localhost:5173
CREATE_TABLES_ON_START=false
DEFAULT_SUPERADMIN_USERNAME=superadmin
DEFAULT_SUPERADMIN_PASSWORD=replace-with-a-strong-password
